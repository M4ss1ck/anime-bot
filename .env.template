BOT_TOKEN=<your_token>
ADMIN_ID=<your_tg_id>

# Runtime DB (used by the bot via the libSQL Prisma adapter).
# Local dev: file:./dev.db    Production: libsql://<your-db>.turso.io
TURSO_DATABASE_URL=file:./dev.db
# Required for remote Turso URLs; leave blank for local file: URLs.
TURSO_AUTH_TOKEN=

# Used only by the Prisma CLI (prisma db push / studio / migrate diff) against a local SQLite file.
# Production deployments do NOT need this — schema is synced to Turso via scripts/sync-turso-schema.ts.
DATABASE_URL=file:./dev.db

# API SERVICES
HARDCOVER_API_TOKEN=

# NEW
NODE_ENV=development        # Set to 'production' in Coolify to enable webhook mode
PORT=3000                   # Elysia listen port (must match Coolify exposed port)
WEBHOOK_DOMAIN=https://your-coolify-domain.com
